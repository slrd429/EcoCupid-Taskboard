function runSync(isManual = false) {

  const lock = LockService.getScriptLock();

  let runtime = null;

  try {

    lock.waitLock(LOCK_WAIT_MS);

  } catch (err) {

    Logger.log(
      "[EcoCupid Sync] Another synchronization is already running."
    );

    return {
      success: false,
      reason: "LOCK_TIMEOUT"
    };

  }

  try {

    runtime = createRuntime(isManual);

    debugLog("Synchronization started.");

    // ============================================================
    // Calendar → Sheet
    // ============================================================

    calendarPhase1(runtime);

    matchCalendarEvents(runtime);

    syncExistingCalendarTasks(runtime);

    importCalendarTasks(runtime);

    finalizeCalendarSync(runtime);

    // ============================================================
    // Sheet → Calendar
    // ============================================================

    syncSheetToCalendar(runtime);

    runtime.summary.success = true;

    logSummary(runtime.summary);

    return runtime.summary;

  } catch (err) {

    if (runtime && runtime.summary) {
      runtime.summary.errors++;
    }

    Logger.log(
      "[EcoCupid Sync] ERROR: " + err.message
    );

    throw err;

  } finally {

    lock.releaseLock();

  }

}

/**
 * Builds the runtime object used throughout the sync.
 */
function createRuntime(isManual) {

  const spreadsheet =
    SpreadsheetApp.getActiveSpreadsheet();

  const sheet =
    spreadsheet.getSheetByName(SHEET_NAME);

  if (!sheet) {
    throw new Error(
      `Sheet "${SHEET_NAME}" not found.`
    );
  }

  const calendar =
    CalendarApp.getCalendarById(CALENDAR_ID);

  if (!calendar) {
    throw new Error(
      "Calendar could not be opened."
    );
  }

  return {

    startedAt: new Date(),

    isManual,

    spreadsheet,

    sheet,

    calendar,

    summary: createSummary(),

    // Calendar → Sheet
    calendarEvents: [],
    calendarEventMap: new Map(),

    // Sheet → Calendar
    sheetTasks: [],
    validTasks: [],
    invalidTasks: [],
    closedTasks: [],

    // Batched spreadsheet writes
    pendingUpdates: new Map()

  };

}

/**
 * Creates a blank synchronization summary.
 */
function createSummary() {

  return {

    success: false,

    scannedTasks: 0,

    scannedEvents: 0,

    matchedEvents: 0,

    unmatchedEvents: 0,

    imported: 0,

    updated: 0,

    unchanged: 0,

    createdEvents: 0,

    updatedEvents: 0,

    deletedEvents: 0,

    repairedRows: 0,

    warnings: 0,

    errors: 0

  };

}

/**
 * Writes debug messages only when DEBUG_MODE is enabled.
 */
function debugLog(message) {

  if (!DEBUG_MODE) return;

  Logger.log(
    "[EcoCupid Sync] " + message
  );

}

/**
 * Logs the synchronization summary.
 */
function logSummary(summary) {

  Logger.log("========== EcoCupid Sync ==========");

  Logger.log("Success: " + summary.success);

  Logger.log("Tasks Scanned: " + summary.scannedTasks);

  Logger.log("Events Scanned: " + summary.scannedEvents);

  Logger.log("Matched Events: " + summary.matchedEvents);

  Logger.log("Unmatched Events: " + summary.unmatchedEvents);

  Logger.log("Imported Tasks: " + summary.imported);

  Logger.log("Updated Tasks: " + summary.updated);

  Logger.log("Unchanged Tasks: " + summary.unchanged);

  Logger.log("Events Created: " + summary.createdEvents);

  Logger.log("Events Updated: " + summary.updatedEvents);

  Logger.log("Events Deleted: " + summary.deletedEvents);

  Logger.log("Rows Repaired: " + summary.repairedRows);

  Logger.log("Warnings: " + summary.warnings);

  Logger.log("Errors: " + summary.errors);

  Logger.log("===================================");

}

