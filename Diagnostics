/**
 * Runs the complete system health check.
 *
 * Returns an object describing the current
 * health of the EcoCupid synchronization system.
 */
function runHealthCheck() {

  const report = {

    passed: true,

    checks: [],

    warnings: [],

    errors: []

  };

  checkSpreadsheet(report);

  checkCalendar(report);

  checkConfig(report);

  checkTemplateRow(report);

  checkColumns(report);

  report.passed =
    report.errors.length === 0;

  return report;

}

/**
 * Runs the health check and writes the
 * results to the execution log.
 */
function showHealthCheck() {

  const report =
    runHealthCheck();

  const lines = [];

  lines.push(
    "========== EcoCupid System Health =========="
  );

  lines.push("");

  report.checks.forEach(check => {

    lines.push(
      "🟢 " + check
    );

  });

  report.warnings.forEach(warning => {

    lines.push(
      "🟡 " + warning
    );

  });

  report.errors.forEach(error => {

    lines.push(
      "🔴 " + error
    );

  });

  lines.push("");

  lines.push(
    report.passed
      ? "Overall Status: HEALTHY ✅"
      : "Overall Status: FAILED ❌"
  );

  Logger.log(
    lines.join("\n")
  );

  return report;

}

/**
 * Verifies that the required spreadsheet
 * sheets exist.
 */
function checkSpreadsheet(report) {

  const ss =
    SpreadsheetApp.getActiveSpreadsheet();

  const tasks =
    ss.getSheetByName(SHEET_NAME);

  const team =
    ss.getSheetByName(TEAM_SHEET_NAME);

  if (tasks) {

    report.checks.push(
      `Tasks sheet found (${SHEET_NAME})`
    );

  } else {

    report.errors.push(
      `Missing Tasks sheet (${SHEET_NAME})`
    );

  }

  if (team) {

    report.checks.push(
      `Team sheet found (${TEAM_SHEET_NAME})`
    );

  } else {

    report.errors.push(
      `Missing Team sheet (${TEAM_SHEET_NAME})`
    );

  }

}

/**
 * Verifies that the configured calendar
 * can be opened.
 */
function checkCalendar(report) {

  try {

    const calendar =
      getTaskCalendar();

    report.checks.push(
      `Calendar connected (${calendar.getName()})`
    );

  } catch (err) {

    report.errors.push(
      "Unable to open configured Calendar."
    );

  }

}

/**
 * Verifies that the configuration values
 * are present.
 */
function checkConfig(report) {

  if (!CALENDAR_ID) {

    report.errors.push(
      "CALENDAR_ID missing."
    );

  }

  if (!SHEET_NAME) {

    report.errors.push(
      "SHEET_NAME missing."
    );

  }

  if (!TEAM_SHEET_NAME) {

    report.errors.push(
      "TEAM_SHEET_NAME missing."
    );

  }

  if (
    typeof NUM_COLUMNS === "undefined" ||
    NUM_COLUMNS <= 0
  ) {

    report.errors.push(
      "NUM_COLUMNS invalid."
    );

  }

  if (report.errors.length === 0) {

    report.checks.push(
      "Configuration loaded."
    );

  }

}

/**
 * Ensures the template row exists.
 */
function checkTemplateRow(report) {

  const sheet =
    SpreadsheetApp
      .getActiveSpreadsheet()
      .getSheetByName(SHEET_NAME);

  if (!sheet) return;

  if (
    sheet.getLastRow() < TEMPLATE_ROW
  ) {

    report.errors.push(
      `Template row ${TEMPLATE_ROW} not found.`
    );

    return;

  }

  report.checks.push(
    `Template row ${TEMPLATE_ROW} found.`
  );

}

/**
 * Verifies the sheet contains enough columns
 * for the configured schema.
 */
function checkColumns(report) {

  const sheet =
    SpreadsheetApp
      .getActiveSpreadsheet()
      .getSheetByName(SHEET_NAME);

  if (!sheet) return;

  const columns =
    sheet.getLastColumn();

  if (
    columns < NUM_COLUMNS
  ) {

    report.errors.push(
      `Sheet has ${columns} columns but ${NUM_COLUMNS} expected.`
    );

    return;

  }

  report.checks.push(
    `${columns} columns detected.`
  );

}

