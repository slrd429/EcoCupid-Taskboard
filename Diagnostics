    "Missing Due Dates: " +
    report.missingDueDates.length
  );

  if (report.missingDueDates.length > 0) {

    Logger.log("");
    Logger.log("Tasks Missing Due Dates:");

    report.missingDueDates.forEach(item => {

      Logger.log(
        `• Row ${item.row} | ${item.taskId} | ${item.description}`
      );

    });

  }

  Logger.log("");

  Logger.log(
