/**
 * Audits synchronization integrity between
 * the spreadsheet and Google Calendar.
 */
function runIntegrityAudit() {

  const report = {

    checked: 0,

    missingCalendarEvents: [],

    dateMismatches: []

  };

  auditCalendarIntegrity(report);

  logIntegrityReport(report);

  return report;

}

/**
 * Logs the integrity audit summary.
 */
function logIntegrityReport(report) {

  Logger.log(
    "========== Sync Integrity Audit =========="
  );

  Logger.log(
    "Tasks Checked: " +
    report.checked
  );

  Logger.log(
    "Missing Calendar Events: " +
    report.missingCalendarEvents.length
  );

  if (report.missingCalendarEvents.length > 0) {

    Logger.log("");

    Logger.log("Affected Tasks:");

    report.missingCalendarEvents.forEach(item => {

      Logger.log(
        `• Row ${item.row} | ${item.taskId} | ${item.description}`
      );

    });

  }

  Logger.log(
    "Date Mismatches: " +
    report.dateMismatches.length
  );

  if (report.dateMismatches.length > 0) {

    Logger.log("");

    Logger.log("Affected Tasks:");

    report.dateMismatches.forEach(item => {

      Logger.log(
        `• Row ${item.row} | ${item.taskId}`
      );

      Logger.log(
        `    Sheet: ${item.sheetDate}`
      );

      Logger.log(
        `    Calendar: ${item.calendarDate}`
      );

    });

  }

  Logger.log(
    "=========================================="
  );

}

/**
 * Audits every active synchronized task.
 */
function auditCalendarIntegrity(report) {

  const sheet =
    SpreadsheetApp
      .getActiveSpreadsheet()
      .getSheetByName(SHEET_NAME);

  const lastRow =
    sheet.getLastRow();

  if (lastRow <= 1) return;

  const rows =
    sheet
      .getRange(
        2,
        1,
        lastRow - 1,
        NUM_COLUMNS
      )
      .getValues();

  const eventMap =
    buildCalendarEventMap();

  rows.forEach((row, index) => {

    const task =
      buildTaskObject(
        row,
        index + 2
      );

    if (

      task.eventId === "" ||

      CLOSED_STATUSES.includes(
        task.status
      )

    ) {

      return;

    }

    report.checked++;

    auditSingleTask(
      task,
      eventMap,
      report
    );

  });

}

/**
 * Audits one task using the cached
 * Calendar event map.
 */
function auditSingleTask(
  task,
  eventMap,
  report
) {

  const event =
    eventMap.get(
      task.eventId
    );

  if (!event) {

    report.missingCalendarEvents.push({

      row: task.row,

      taskId: task.taskId,

      description: task.description,

      eventId: task.eventId

    });

    return;

  }

  if (!task.dueDate) {

    return;

  }

  const sheetDate =
    Utilities.formatDate(

      new Date(task.dueDate),

      Session.getScriptTimeZone(),

      "yyyyMMdd"

    );

  const calendarDate =
    Utilities.formatDate(

      event.getAllDayStartDate(),

      Session.getScriptTimeZone(),

      "yyyyMMdd"

    );

  if (

    sheetDate !==
    calendarDate

  ) {

    report.dateMismatches.push({

      row: task.row,

      taskId: task.taskId,

      description: task.description,

      eventId: task.eventId,

      sheetDate,

      calendarDate

    });

  }

}

/**
 * Builds a lookup map of
 * Event ID → Calendar Event.
 */
function buildCalendarEventMap() {

  const map =
    new Map();

  const events =
    getCalendarEvents();

  events.forEach(event => {

    map.set(

      event.getId(),

      event

    );

  });

  return map;

}

