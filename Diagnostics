    Logger.log("Tasks with Invalid Event IDs:");

    report.invalidEventIds.forEach(item => {

      Logger.log(
        `• Row ${item.row} | ${item.taskId} | ${item.description}`
      );

    });

  }

  Logger.log(
    "Missing Task IDs: " +
