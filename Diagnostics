/**
 * Runs all duplicate detection diagnostics.
 */
function runDuplicateCheck() {

  const report = {

    duplicateTaskIds: [],

    duplicateEventIds: [],

    blankTaskIds: [],

    blankEventIds: [],

    orphanCalendarEvents: []

  };

  findSheetDuplicates(report);

  findCalendarOrphans(report);

  logDuplicateReport(report);

  return report;

}

/**
 * Logs the duplicate detection report.
 */
function logDuplicateReport(report) {

  Logger.log(
    "========== Duplicate Detection =========="
  );

  Logger.log(
    "Duplicate Task IDs: " +
    report.duplicateTaskIds.length
  );

  Logger.log(
    "Duplicate Event IDs: " +
    report.duplicateEventIds.length
  );

  Logger.log(
    "Blank Task IDs: " +
    report.blankTaskIds.length
  );

  Logger.log(
    "Blank Event IDs: " +
    report.blankEventIds.length
  );

  Logger.log(
    "Orphan Calendar Events: " +
    report.orphanCalendarEvents.length
  );

  Logger.log(
    "========================================="
  );

}

/**
 * Detects duplicate Task IDs and Event IDs
 * within the spreadsheet.
 *
 * Only reports missing Event IDs for
 * active tasks that should be synchronized.
 */
function findSheetDuplicates(report) {

  const sheet =
    SpreadsheetApp
      .getActiveSpreadsheet()
      .getSheetByName(SHEET_NAME);

  const lastRow =
    sheet.getLastRow();

  if (lastRow <= 1) return;

  const rows =
    sheet
      .getRange(
        2,
        1,
        lastRow - 1,
        NUM_COLUMNS
      )
      .getValues();

  const taskIds = new Map();
  const eventIds = new Map();

  rows.forEach((row, index) => {

    const rowNumber = index + 2;

    const task =
      buildTaskObject(
        row,
        rowNumber
      );

    const hasContent =
      task.description !== "" ||
      task.dueDate;

    if (!hasContent) return;

    // ----------------------------
    // Task ID
    // ----------------------------

    if (task.taskId === "") {

      report.blankTaskIds.push(
        rowNumber
      );

    } else {

      if (!taskIds.has(task.taskId)) {

        taskIds.set(
          task.taskId,
          []
        );

      }

      taskIds
        .get(task.taskId)
        .push(rowNumber);

    }

    // ----------------------------
    // Event ID
    // ----------------------------

    const shouldHaveEvent =

      task.dueDate &&

      !CLOSED_STATUSES.includes(
        task.status
      );

    if (shouldHaveEvent) {

      if (task.eventId === "") {

        report.blankEventIds.push(
          rowNumber
        );

      } else {

        if (!eventIds.has(task.eventId)) {

          eventIds.set(
            task.eventId,
            []
          );

        }

        eventIds
          .get(task.eventId)
          .push(rowNumber);

      }

    }

  });

  taskIds.forEach((rows, id) => {

    if (rows.length > 1) {

      report.duplicateTaskIds.push({

        id,

        rows

      });

    }

  });

  eventIds.forEach((rows, id) => {

    if (rows.length > 1) {

      report.duplicateEventIds.push({

        id,

        rows

      });

    }

  });

}

/**
 * Detects EcoCupid Calendar events that are
 * no longer linked to a spreadsheet task.
 */
function findCalendarOrphans(report) {

  const sheet =
    SpreadsheetApp
      .getActiveSpreadsheet()
      .getSheetByName(SHEET_NAME);

  const lastRow =
    sheet.getLastRow();

  const sheetEventIds =
    new Set();

  if (lastRow > 1) {

    sheet
      .getRange(
        2,
        COL.EVENT_ID + 1,
        lastRow - 1,
        1
      )
      .getValues()
      .flat()
      .forEach(id => {

        id =
          normalizeString(id);

        if (id !== "") {

          sheetEventIds.add(id);

        }

      });

  }

  const events =
    getCalendarEvents();

  events.forEach(event => {

    const id =
      event.getId();

    // Ignore manually-created calendar events.
    if (
      !event
        .getDescription()
        .includes("Task ID:")
    ) {

      return;

    }

    if (!sheetEventIds.has(id)) {

      report.orphanCalendarEvents.push({

        id,

        title:
          event.getTitle(),

        date:
          event.getAllDayStartDate()

      });

    }

  });

}

