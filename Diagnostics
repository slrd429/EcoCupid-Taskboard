/**
 * Finds rows that could be repaired.
 */
function findRepairCandidates(report) {

  const sheet =
    SpreadsheetApp
      .getActiveSpreadsheet()
      .getSheetByName(SHEET_NAME);

  const lastRow =
    sheet.getLastRow();

  if (lastRow <= 1) return;

  const rows =
    sheet
      .getRange(
        2,
        1,
        lastRow - 1,
        NUM_COLUMNS
      )
      .getValues();

  const eventMap =
    buildCalendarEventMap();

  rows.forEach((row, index) => {

    const task =
      buildTaskObject(
        row,
        index + 2
      );

    if (isEmptyTask(task)) {

      return;

    }

    evaluateRepairCandidate(
      task,
      eventMap,
      report
    );

  });

}

/**
 * Evaluates one task for repair opportunities.
 */
function evaluateRepairCandidate(
  task,
  eventMap,
  report
) {

  const taskInfo = {

    row: task.row,

    taskId: task.taskId,

    description: task.description,

    eventId: task.eventId

  };

  if (task.taskId === "") {

    report.missingTaskIds.push(taskInfo);

    report.actions.generateTaskIds.push(taskInfo);

    report.repairable++;

  }

  if (
    task.description !== "" &&
    !task.dueDate
  ) {

    report.missingDueDates.push(taskInfo);

    report.actions.manualReview.push(taskInfo);

  }

  if (
    isClosedTask(task)
  ) {

    return;

  }

  if (
    task.eventId === ""
  ) {

    report.missingEventIds.push(taskInfo);

    report.actions.createCalendarEvents.push(taskInfo);

    report.repairable++;

    return;

  }

  if (
    !eventMap.has(task.eventId)
  ) {

    report.invalidEventIds.push(taskInfo);

    report.actions.recreateCalendarEvents.push(taskInfo);

    report.repairable++;

  }

}

// =========================================================================
// Unit 5
// System Status Report
// =========================================================================

/**
 * Runs every diagnostic module and
 * displays an overall system status.
 */
function runSystemReport() {

  const health =
    runHealthCheck();

  const duplicates =
    runDuplicateCheck();

  const integrity =
    runIntegrityAudit();

  const repairs =
    runRepairAdvisor();

  const status =
    buildSystemStatus(

      health,

      duplicates,

      integrity,

      repairs

    );

  logSystemReport(status);

  return status;

}

/**
 * Combines all diagnostic reports into
 * one overall system report.
 */
function buildSystemStatus(

  health,

  duplicates,

  integrity,

  repairs

) {

  const healthy =

    health.errors.length === 0 &&

    duplicates.duplicateTaskIds.length === 0 &&

    duplicates.duplicateEventIds.length === 0 &&

    duplicates.blankTaskIds.length === 0 &&

    duplicates.blankEventIds.length === 0 &&

    duplicates.orphanCalendarEvents.length === 0 &&

    integrity.missingCalendarEvents.length === 0 &&

    integrity.dateMismatches.length === 0 &&

    repairs.repairable === 0;

  return {

    timestamp:

      new Date(),

    version:

      SYSTEM_VERSION,

    healthy,

    health,

    duplicates,

    integrity,

    repairs

  };

}

/**
 * Formats a PASS / FAIL status.
 */
function formatStatus(pass) {

  return pass

    ? "PASS ✅"

    : "FAIL ❌";

}

/**
 * Logs the complete system report.
 */
function logSystemReport(report) {

  Logger.log("");

  Logger.log(
    "=========================================="
  );

  Logger.log(
    "EcoCupid Taskboard Sync v" +
    report.version
  );

  Logger.log("");

  Logger.log(
  "Health Check ........ " +

  formatStatus(

    report.health.errors.length === 0

  )

  );

  Logger.log(
  "Duplicate Check ..... " +

  formatStatus(

    report.duplicates.duplicateTaskIds.length === 0 &&

    report.duplicates.duplicateEventIds.length === 0 &&

    report.duplicates.orphanCalendarEvents.length === 0

  )

  );

  Logger.log(
  "Integrity Audit ..... " +

  formatStatus(

    report.integrity.missingCalendarEvents.length === 0 &&

    report.integrity.dateMismatches.length === 0

  )

  );

  Logger.log(
  "Repair Advisor ...... " +

  formatStatus(

    report.repairs.repairable === 0

  )

  );

  Logger.log("");

  Logger.log(
    "Overall Status"
  );

  Logger.log("");

  Logger.log(

    report.healthy

      ? "🟢 PRODUCTION READY"

      : "🔴 ATTENTION REQUIRED"

  );

  Logger.log("");

  Logger.log(
    "Generated: " +
    Utilities.formatDate(

      report.timestamp,

      Session.getScriptTimeZone(),

      "yyyy-MM-dd HH:mm:ss"

    )

  );

  Logger.log(
    "=========================================="
  );

}

