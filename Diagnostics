/**
 * Scans the taskboard for issues that can
 * be repaired automatically.
 */
function runRepairAdvisor() {

  const report = {

    missingEventIds: [],

    invalidEventIds: [],

    missingTaskIds: [],

    missingDueDates: [],

    actions: {

      createCalendarEvents: [],

      recreateCalendarEvents: [],

      generateTaskIds: [],

      manualReview: []

    },

    repairable: 0

  };

  findRepairCandidates(report);

  logRepairReport(report);

  return report;

}

