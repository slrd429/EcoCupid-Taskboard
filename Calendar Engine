// Calendar CRUD
// =========================================================================

/**
 * Creates a new Calendar event from a task.
 *
 * @param {Object} task Normalized task object
 * @returns {CalendarEvent}
 */
function calendarCreateEvent(task) {

  const event =
    getTaskCalendar().createAllDayEvent(

      buildCalendarTitle(task),

      new Date(task.dueDate)

    );

  applyCalendarFormatting(
    event,
    task
  );

  setEventReminders(
    event,
    task.reminderDays
  );

  return event;

}

/**
 * Updates an existing Calendar event.
 *
 * Returns the updated event,
 * or null if the Event ID is invalid.
 *
 * @param {Object} task Normalized task object
 */
function calendarUpdateEvent(task) {

  const event =
    findCalendarEvent(task.eventId);

  if (!event) {
    return null;
  }

  event.setAllDayDate(
    new Date(task.dueDate)
  );

  applyCalendarFormatting(
    event,
    task
  );

  setEventReminders(
    event,
    task.reminderDays
  );

  return event;

}

/**
 * Deletes a Calendar event.
 *
 * Returns true if deleted.
 * Returns false if already missing.
 *
 * @param {String} eventId
 */
function calendarDeleteEvent(eventId) {

  const event =
    findCalendarEvent(eventId);

  if (!event) {
    return false;
  }

  event.deleteEvent();

  return true;

}

// =========================================================================
// Unit 3
// Reminder Management
// =========================================================================

/**
 * Applies the configured popup reminder.
 *
 * Google Apps Script does not provide a way to
 * remove existing popup reminders from events.
 *
 * Therefore reminders are only added when a task
 * specifies a valid reminder value.
 */
function setEventReminders(event, reminderDays) {

  if (!event) {
    return;
  }

  const days =
    parseReminderDays(reminderDays);

  if (days === null) {
    return;
  }

  const minutes =
    days * 24 * 60;

  const existing =
    event.getPopupReminders();

  if (

    existing.includes(minutes)

  ) {

    return;

  }

  event.addPopupReminder(
    minutes
  );

}

/**
 * Converts the sheet value into a valid reminder.
 *
 * Returns:
 *   Number -> valid reminder days
 *   null   -> no reminder
 */
function parseReminderDays(value) {

  if (

    value === "" ||

    value === null ||

    value === undefined

  ) {

    return null;

  }

  const days =
    Number(value);

  if (

    Number.isNaN(days) ||

    days <= 0

  ) {

    return null;

  }

  return Math.floor(days);

}

