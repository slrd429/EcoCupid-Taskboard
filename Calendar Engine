/**
 * Returns the configured Google Calendar.
 */
function getTaskCalendar() {

  const calendar =
    CalendarApp.getCalendarById(CALENDAR_ID);

  if (!calendar) {

    throw new Error(
      "Unable to open the configured calendar."
    );

  }

  return calendar;

}

/**
 * Looks up a Calendar event by ID.
 *
 * Returns null if the event no longer exists.
 */
function findCalendarEvent(eventId) {

  if (!eventId) {
    return null;
  }

  try {

    return getTaskCalendar()
      .getEventById(eventId);

  } catch (err) {

    return null;

  }

}

/**
 * Returns all events within the configured sync window.
 */
function getCalendarEvents() {

  const today = new Date();

  const start =
    new Date(today);

  start.setDate(
    start.getDate() - SYNC_LOOKBACK_DAYS
  );

  const end =
    new Date(today);

  end.setDate(
    end.getDate() + SYNC_LOOKAHEAD_DAYS
  );

  return getTaskCalendar()
    .getEvents(start, end);

}

