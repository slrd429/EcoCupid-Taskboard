/**
 * Builds the Calendar event title.
 *
 * Format:
 * [Assignee] Task Description
 */
/**
 * Builds the Calendar event title.
 *
 * Format:
 * 🚨 Overdue | [Assignee] Task
 * 🛑 Blocked | [Assignee] Task
 * [Assignee] Task
 */
function buildCalendarTitle(task) {

  let prefix = "";

  const status =
    normalizeString(task.status);

  if (status === STATUS.BLOCKED) {

    prefix = "🛑 Blocked | ";

  } else if (

    !isClosedTask(task) &&
    task.dueDate instanceof Date

  ) {

    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const due =
      new Date(task.dueDate);
    due.setHours(0, 0, 0, 0);

    if (due < today) {

      prefix = "🚨 Overdue | ";

    }

  }

  const assignee =
    normalizeString(task.assignee) ||
    "Unassigned";

  const description =
    normalizeString(task.description);

  return `${prefix}[${assignee}] ${description}`;

}

/**
 * Builds the Calendar event description.
 *
 * Keeps useful metadata visible directly inside
 * Google Calendar.
 */
function buildCalendarDescription(task) {

  const lines = [];

  lines.push(
    `Task ID: ${task.taskId || "-"}`
  );

  lines.push(
    `Assignee: ${task.assignee || "-"}`
  );

  lines.push(
    `Status: ${task.status || "-"}`
  );

  if (task.notes) {

    lines.push("");

    lines.push("Notes:");

    lines.push(task.notes);

  }

  return lines.join("\n");

}

function applyCalendarFormatting(event, task) {

  if (!event) {
    return;
  }

  event.setTitle(
    buildCalendarTitle(task)
  );

  event.setDescription(
    buildCalendarDescription(task)
  );

}

/**
 * Returns the comparable state of a Calendar event.
 *
 * Only fields that actually exist in Calendar
 * are included.
 */
function getCalendarState(event) {

  return {

    dueDate:
      Utilities.formatDate(

        event.getAllDayStartDate(),

        Session.getScriptTimeZone(),

        "yyyy-MM-dd"

      )

  };

}
